# Copy to .env and fill in. Nothing here is secret: secrets themselves live in
# 1Password (or, for unattended runs, in the 0600 env file that
# `seb-sync bootstrap` writes). These values just say *where* to find them.

# --- 1Password coordinates ---
# No defaults in code: they describe your own vault and this repo is public.
# `op` picks an arbitrary account when you have more than one, so pin it.
#   op account list                 -> the account id
#   op item list --vault Personal   -> the item ids
# Reference items by ID, not title: `op read` rejects titles containing
# characters like an em-dash ("invalid character in secret reference").
OP_ACCOUNT=YOUR_1PASSWORD_ACCOUNT_ID
OP_VAULT=Personal
EB_ITEM=YOUR_ENABLEBANKING_ITEM_ID
LM_OP_ITEM=YOUR_LUNCHMONEY_ITEM_ID
LM_OP_FIELD=credential

# --- Direct overrides (skip 1Password entirely) ---
# What `seb-sync bootstrap` writes, and what unattended runs use — a launchd
# or cron job cannot answer a 1Password unlock prompt.
# EB_APPLICATION_ID=00000000-0000-0000-0000-000000000000
# EB_PRIVATE_KEY_PATH=~/.config/enablebanking/enablebanking-private.pem
# LUNCHMONEY_API_TOKEN=

# --- Enable Banking ---
EB_BASE_URL=https://api.enablebanking.com
# https is required; http is rejected as "unsupported scheme".
EB_REDIRECT_URL=https://localhost:8080/callback
EB_ASPSP_NAME=SEB
EB_ASPSP_COUNTRY=SE
# Must match the "usage type" chosen when linking the account in the Enable
# Banking control panel, otherwise consent fails after you have already done
# the BankID round. Override per run with `seb-sync auth --psu-type business`.
EB_PSU_TYPE=personal

# --- Lunch Money ---
LM_BASE_URL=https://dev.lunchmoney.app

# Local consent-callback listener (one-time BankID redirect)
CALLBACK_HOST=localhost
CALLBACK_PORT=8080
