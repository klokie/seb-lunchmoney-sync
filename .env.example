# Copy to .env and adjust. Secrets are pulled from 1Password by default (see
# secrets.py); these env vars override the op lookups if set.

# --- Enable Banking ---
# Personal 1Password account (grossfeld). The CLI defaults to the WERLABS work
# account, so the account id is pinned explicitly.
OP_ACCOUNT=56RHUXXFBNAPJKCJUZ22YN36NE
OP_VAULT=Personal
EB_ITEM=Enable Banking — klokie-lunchmoney-sync

# Overrides (leave unset to read from 1Password):
# EB_APPLICATION_ID=c6d71c81-d35e-4adc-a635-a7ee53a25e3c
# EB_PRIVATE_KEY_PATH=~/.config/enablebanking/enablebanking-private.pem

EB_BASE_URL=https://api.enablebanking.com
EB_REDIRECT_URL=https://localhost:8080/callback
EB_ASPSP_NAME=SEB
EB_ASPSP_COUNTRY=SE
EB_PSU_TYPE=business

# --- Lunch Money ---
# Token also in 1Password (item 3vrk4of6otddew56uuo5icpofa, field credential).
# LUNCHMONEY_API_TOKEN=
LM_OP_ITEM=3vrk4of6otddew56uuo5icpofa
LM_OP_FIELD=credential

# Local consent-callback listener (one-time BankID redirect)
CALLBACK_HOST=localhost
CALLBACK_PORT=8080
